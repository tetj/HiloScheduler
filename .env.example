# Path to store ecobee HomeKit pairing credentials (created by --pair step)
# Default is ecobee_pairing.json in the same folder as the script
PAIRING_FILE=ecobee_pairing.json

# Temperature setpoints (°C)
TEMP_PREHEAT_LOW=24.0    # first 90 min of preheat window
TEMP_PREHEAT_HIGH=25.0   # last 30 min before event starts
TEMP_REDUCTION=16.0      # during the peak event
EVENT_DURATION_MIN=240   # event length in minutes (4 hours)

# Preheat window timing
PREHEAT_TOTAL_MIN=120    # total preheat window (2 hours before event)
PREHEAT_HIGH_MIN=30      # how many minutes before event to boost to high temp
